#!/usr/bin/env zsh
# ─── aliases ──────────────────────────────────────────────────────────────────

# ─── Directory listing (eza) ──────────────────────────────────────────────────
alias ls='eza --hyperlink --group-directories-first'
alias ll='eza -la --icons --git --hyperlink --group-directories-first'
alias la='eza -a --icons --hyperlink --group-directories-first'
alias lt='eza --tree --level=2 --icons'
alias tree='eza --tree --icons'

# ─── File operations (safe defaults) ─────────────────────────────────────────
alias cp='cp -i'
alias mv='mv -i'
alias rm='rm -i'
alias mkdir='mkdir -p'

# ─── Pager / viewer ──────────────────────────────────────────────────────────
if command -v batcat &>/dev/null; then
    alias cat='batcat --paging=never'
    alias bat='batcat'
elif command -v bat &>/dev/null; then
    alias cat='bat --paging=never'
fi

# ─── Grep with color ─────────────────────────────────────────────────────────
alias grep='grep --color=auto'

# ─── ripgrep ─────────────────────────────────────────────────────────────────
alias rg='rg --hyperlink-format=kitty --color=auto --smart-case'

# ─── delta ───────────────────────────────────────────────────────────────────
alias delta="delta --hyperlinks --hyperlinks-file-link-format='file://{path}#{line}'"

# ─── Git ─────────────────────────────────────────────────────────────────────
alias g='git'
alias gs='git status -sb'
alias ga='git add'
alias gaa='git add --all'
alias gc='git commit -v'
alias gcm='git commit -m'
alias gca='git commit --amend --no-edit'
alias gd='git diff'
alias gds='git diff --staged'
alias gpl='git pull --rebase'
alias gps='git push'
alias gpf='git push --force-with-lease'
alias gl='git log --oneline --graph --decorate --all'
alias gco='git checkout'
alias gb='git branch'
alias gst='git stash'
alias gstp='git stash pop'

# ─── Quick navigation ─────────────────────────────────────────────────────────
alias workspace="cd $WORKSPACE"
alias cfg="cd $XDG_CONFIG_HOME"
alias dotfiles="cd $DOTFILES"

# ─── Clipboard (Linux) ───────────────────────────────────────────────────────
if command -v xclip &>/dev/null; then
    alias pbcopy='xclip -selection clipboard'
    alias pbpaste='xclip -selection clipboard -o'
fi

# ─── Neovim ──────────────────────────────────────────────────────────────────
alias v='nvim'
alias vi='nvim'
